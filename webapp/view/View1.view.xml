<mvc:View controllerName="sapui5project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core" displayBlock="true">
    <Page id="page" title="{i18n>dashboardTitle}" showHeader="false" class="dashboardPage3D">
        <content>
            <!-- Background Container for 3D animated particles/glow -->
            <div xmlns="http://www.w3.org/1999/xhtml" class="background-3d">
                <div class="sphere-glow sphere-glow-1"></div>
                <div class="sphere-glow sphere-glow-2"></div>
            </div>

            <!-- Main Dashboard Layout -->
            <VBox class="dashboardContainer" fitContainer="true">

                <!-- Header Section inside 3D Perspective -->
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="header3D glassPanel">
                    <VBox>
                        <Title text="Employee Hub" class="premiumTitle" level="H1"/>
                        <Text text="Manage and monitor your workforce" class="subTitle"/>
                    </VBox>
                    <Button text="{i18n>btnCreateEmployee}" icon="sap-icon://add-employee" press=".onCreateEmployee" class="btnPremium3D" />
                </HBox>

                <!-- KPI Widgets in 3D Grid Layout -->
                <HBox class="kpiGrid" justifyContent="SpaceBetween" wrap="Wrap">
                    <VBox class="kpiCard glassPanel floatAnim">
                        <core:Icon src="sap-icon://employee" class="kpiIcon"/>
                        <Text text="{i18n>statTotalEmployees}" class="kpiLabel" />
                        <Title text="{/TotalEmployees}" class="kpiValue" />
                    </VBox>
                    <VBox class="kpiCard glassPanel floatAnim floatDelay1">
                        <core:Icon src="sap-icon://sys-enter-2" class="kpiIcon iconActive"/>
                        <Text text="{i18n>statActive}" class="kpiLabel" />
                        <Title text="{/ActiveEmployees}" class="kpiValue" />
                    </VBox>
                    <VBox class="kpiCard glassPanel floatAnim floatDelay2">
                        <core:Icon src="sap-icon://away" class="kpiIcon iconLeave"/>
                        <Text text="{i18n>statOnLeave}" class="kpiLabel" />
                        <Title text="{/OnLeaveEmployees}" class="kpiValue" />
                    </VBox>
                </HBox>

                <!-- Recent Employees List Layout -->
                <VBox class="listContainer glassPanel slideUpAnim">
                    <Title text="Saved Employees" class="listTitle" level="H3"/>
                    <Table items="{/Employees}" backgroundDesign="Transparent" class="employeeTable3D">
                        <columns>
                            <Column width="5em" hAlign="Center">
                                <Text text="S.No." class="tableHeader3D"/>
                            </Column>
                            <Column>
                                <Text text="Employee ID" class="tableHeader3D"/>
                            </Column>
                            <Column>
                                <Text text="Name" class="tableHeader3D"/>
                            </Column>
                            <Column>
                                <Text text="Department" class="tableHeader3D"/>
                            </Column>
                            <Column width="4em" hAlign="End">
                                <Text text="" class="tableHeader3D"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem vAlign="Middle" class="tableRow3D tiltEffect">
                                <cells>
                                    <Text text="{serialNo}" class="tableCell3D tableCellBold"/>
                                    <Text text="{employeeId}" class="tableCell3D"/>
                                    <HBox alignItems="Center">
                                        <Avatar src="{avatar}" displaySize="XS" class="sapUiTinyMarginEnd" style="border: 2px solid var(--primary-glow);"/>
                                        <Text text="{employeeName}" class="tableCell3D tableCellBold"/>
                                    </HBox>
                                    <Text text="{department}" class="tableCell3D tableCellMuted"/>
                                    <Button icon="sap-icon://delete" press=".onDeleteEmployee" type="Transparent" class="btnDelete3D" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>

            </VBox>
        </content>
    </Page>
</mvc:View>
